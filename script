local function buildOutput(collected, mode)
	local varN = CFG.varName
	local prefix = mode == "gameid" and "game.GameId" or "game.PlaceId"
	local lines = {}
	lines[#lines+1] = "--local " .. varN .. " = " .. prefix
	lines[#lines+1] = ""
	for i, entry in collected do
		local kw = i == 1 and "if" or "elseif"
		lines[#lines+1] = "--" .. entry.name
		if #entry.ids > 1 then
			local parts = {}
			for _, id in entry.ids do
				parts[#parts+1] = varN .. " == " .. id
			end
			lines[#lines+1] = kw .. " " .. table.concat(parts, " or ") .. " then"
		else
			lines[#lines+1] = kw .. " " .. varN .. " == " .. entry.ids[1] .. " then"
		end
		lines[#lines+1] = ""
	end
	if #collected > 0 then lines[#lines+1] = "end" end
	return table.concat(lines, "\n")
end

local RUNNING = false
local stopConn

local function doStop(collected, mode, kicked)
	RUNNING = false
	if stopConn then stopConn:Disconnect() stopConn = nil end
	pcall(function() delfile(AUTO_STATE_FILE) end)
	if #collected > 0 then
		local out = buildOutput(collected, mode)
		setclipboard(out)
		StatusLbl.Text = "Done. " .. #collected .. " collected, copied!"
		Notif("Done! " .. #collected .. " games copied.", 8, "UV Auto")
	else
		StatusLbl.Text = "Stopped. Nothing collected."
	end
	if kicked then
		task.wait(1)
		LP:Kick("UV Automation stopped")
	end
end

local function collectCurrent(s)
	local id = s.mode == "gameid" and tostring(game.GameId) or tostring(game.PlaceId)
	local prevIdx = s.currentIdx - 1
	if prevIdx < 1 or prevIdx > #s.queue then return end
	local name = s.queue[prevIdx].name
	for _, c in s.collected do
		if c.name == name then
			c.ids[#c.ids+1] = id
			return
		end
	end
	s.collected[#s.collected+1] = {name=name, ids={id}}
end

local function runAutoFrom(state)
	RUNNING = true
	stopConn = UIS.InputBegan:Connect(function(inp2, gp)
		if not gp and inp2.KeyCode == Enum.KeyCode.U and RUNNING then
			collectCurrent(state)
			doStop(state.collected, state.mode, true)
		end
	end)

	task.spawn(function()
		collectCurrent(state)

		if state.currentIdx > #state.queue then
			doStop(state.collected, state.mode, false)
			task.wait(2)
			TS:Teleport(state.startPlaceId, LP)
			return
		end

		local entry = state.queue[state.currentIdx]
		StatusLbl.Text = "[" .. state.currentIdx .. "/" .. #state.queue .. "] " .. entry.name
		Notif("TP: " .. entry.name, 3, "UV Auto")

		state.currentIdx += 1
		writefile(AUTO_STATE_FILE, HS:JSONEncode(state))

		local qScript = "loadstring(game:HttpGet('" .. SCRIPT_URL .. "'))()"
		pcall(function()
			if queue_on_teleport then
				queue_on_teleport(qScript)
			elseif queueonteleport then
				queueonteleport(qScript)
			elseif queueteleport then
				queueteleport(qScript)
			end
		end)

		task.wait(0.5)
		TS:Teleport(entry.placeId, LP)
	end)
end

