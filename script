local function toggle(parent, val, cb)
	local s = val
	local b = ni("TextButton", {
		Parent=parent, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0),
		Size=UDim2.new(0,44,0,20),
		BackgroundColor3=s and Color3.fromRGB(70,190,70) or Color3.fromRGB(60,30,80),
		Text=s and "ON" or "OFF", Font=Enum.Font.GothamBold,
		TextColor3=Color3.fromRGB(255,255,255), TextSize=11, ZIndex=10,
	})
	crn(b,10)
	b.MouseButton1Click:Connect(function()
		s = not s
		b.BackgroundColor3 = s and Color3.fromRGB(70,190,70) or Color3.fromRGB(60,30,80)
		b.Text = s and "ON" or "OFF"
		cb(s)
	end)
	return b
end

local function inp(parent, val, cb)
	local tb = ni("TextBox", {
		Parent=parent, BackgroundColor3=Color3.fromRGB(30,15,45),
		AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0),
		Size=UDim2.new(0.44,0,0,20), Font=Enum.Font.Gotham,
		Text=tostring(val), TextColor3=Color3.fromRGB(255,255,255), TextSize=11,
		ClearTextOnFocus=false, ZIndex=10,
	})
	crn(tb,4)
	tb.FocusLost:Connect(function() cb(tb.Text) end)
	return tb
end

