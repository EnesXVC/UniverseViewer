task.spawn(function()
	local attempts = 0
	local page
	Notif("Loading game places, please wait...", 3, "UV")
	while attempts < MAX_RETRIES do
		attempts += 1
		local s,_ = pcall(function() page = AS:GetGamePlacesAsync() end)
		if s then break end
		task.wait(RETRY_DELAY)
	end
	if not page then Notif("Places failed to load!", 6, "UV Error") return end

	local order = 1
	while true do
		for _, place in page:GetCurrentPage() do
			local pid = tostring(place.PlaceId)
			local gid = tostring(game.GameId)
			ALL_PLACE_IDS[#ALL_PLACE_IDS+1] = pid
			if not table.find(ALL_GAME_IDS, gid) then ALL_GAME_IDS[#ALL_GAME_IDS+1] = gid end
			local row = GameTemplate:Clone()
			row.Parent = GamesList row.LayoutOrder = order row.Visible = true
			row.GameButton.Text = " " .. place.Name .. " (" .. pid .. ")"
			row.BH.TP.MouseButton1Click:Connect(function() TS:Teleport(place.PlaceId, LP) Notif("TP: " .. place.Name, 3) end)
			row.BH.CP.MouseButton1Click:Connect(function() setclipboard(pid) Notif("Copied: " .. pid, 3) end)
			order += 1
		end
		if page.IsFinished then break end
		page:AdvanceToNextPageAsync()
	end
end)

